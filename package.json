{
  "name": "dev-survival-kit",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "dev": "npm run env:dev && ng serve",
    "start": "npm run env:dev && ng serve",
    "env:dev": "node scripts/generate-env.mjs development",
    "env:prod": "node scripts/generate-env.mjs production",
    "build": "npm run env:prod && ng build --configuration production",
    "build:pages": "npm run env:prod && ng build --configuration production --base-href /dev-survival-kit-lpnu/",
    "preview": "http-server dist/dev-survival-kit/browser -p 4173 -o",
    "watch": "ng build --watch --configuration development",
    "lint": "eslint \"src/**/*.ts\" --quiet",
    "test": "ng test",
    "test:unit": "ng test --watch=false --browsers=ChromeHeadless",
    "test:coverage": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "serve:ssr:dev-survival-kit": "node dist/dev-survival-kit/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/platform-server": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@angular/ssr": "^19.2.5",
    "express": "^4.18.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.5",
    "@angular/cli": "^19.2.5",
    "@angular/compiler-cli": "^19.2.0",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.18.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "http-server": "^14.1.1",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.8.4",
    "typescript": "~5.7.2"
  }
}
